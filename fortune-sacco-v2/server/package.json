{
  "name": "server",
  "version": "0.1.0",
  "packageManager": "pnpm@10.2.0",
  "type": "module",
  "scripts": {
    "start": "nx run-many -t serve",
    "build": "nx run-many -t build",
    "lint": "nx run-many -t lint",
    "typecheck": "nx run-many -t typecheck",
    "test": "nx run-many -t test",
    "format": "prettier --write '**/*.{js,mjs,json,ts,md}'",
    "clean": "nx run-many -t clean && rimraf node_modules .nx",
    "pre-commit": "nx affected -t lint typecheck --base=HEAD",
    "prepare": "node .husky/install.mjs",
    "syncpack:list": "npx syncpack list-mismatches",
    "syncpack:fix": "npx syncpack fix-mismatches"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.3",
    "@commitlint/cli": "20.5.2",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/js": "^9.8.0",
    "@nx/docker": "22.6.5",
    "@nx/esbuild": "22.6.5",
    "@nx/eslint": "22.6.5",
    "@nx/eslint-plugin": "22.6.5",
    "@nx/js": "22.7.0",
    "@nx/node": "22.6.5",
    "@nx/workspace": "22.6.5",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/node": "catalog:node",
    "eslint": "^9.26.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "husky": "^9.1.7",
    "jsonc-eslint-parser": "^2.1.0",
    "nx": "22.7.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tslib": "^2.3.0",
    "typescript": "catalog:",
    "typescript-eslint": "^8.40.0"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  }
}
